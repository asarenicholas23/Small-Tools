{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PDF Shrinker",
  "version": "0.1.0",
  "identifier": "com.pdfshrinker.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PDF Shrinker",
        "width": 900,
        "height": 760,
        "minWidth": 720,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/pdf-shrinker-ghostscript"],
    "windows": {
      "wix": {
        "language": "en-US"
      },
      "nsis": {}
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      },
      "deb": {
        "depends": []
      }
    },
    "macOS": {
      "dmg": {
        "background": null,
        "windowSize": {
          "width": 660,
          "height": 400
        }
      }
    }
  }
}
